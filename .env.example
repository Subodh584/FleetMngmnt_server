# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.ibkarmajufdlfirdfrki:Aaluparatha%40123@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres

# Redis (optional – falls back to in-memory channel layer if not set)
REDIS_URL=redis://127.0.0.1:6379/0

# CORS (comma-separated origins, only used when DEBUG=False)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# AI Assistant (Mistral + LangChain)
MISTRAL_API_KEY=your-mistral-api-key-here
# Use a read-only Supabase role at port 5432 (direct, NOT PgBouncer port 6543)
AI_ASSISTANT_DB_URL=postgresql://ai_readonly:your-password@db.your-project.supabase.co:5432/postgres
# Optional: switch model for cost savings (default: mistral-large-latest)
# MISTRAL_MODEL=open-mixtral-8x22b

# Email (SMTP)
